# Embedding 模型配置 (Ollama API)
EMBED_BASE_URL=http://localhost:11434
EMBED_MODEL_NAME=bge-m3
EMBED_TIMEOUT=60.0

# MCP 传输模式: sse (守护进程) | stdio (子进程)
MCP_TRANSPORT=sse
MCP_HOST=127.0.0.1
MCP_PORT=8042

# 文档目录路径 (启动时自动加载索引 + 文件监控)
RAG_PROJECT_PATH=./documents

# 混合检索权重 (0.0=纯BM25, 1.0=纯向量, 默认0.7)
RAG_HYBRID_WEIGHT=0.7

# 智能分块参数
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=60

# 文件监控防抖间隔 (秒)
RAG_WATCH_DEBOUNCE=1.0

# 日志级别
LOG_LEVEL=INFO
